# ----------------------------
# BASE IMAGE
# ----------------------------
FROM python:3.11-slim

# ----------------------------
# WORKDIR
# ----------------------------
WORKDIR /app

# ----------------------------
# COPY REQUIREMENTS
# ----------------------------
COPY requirements.txt .

# ----------------------------
# INSTALL DEPENDENCIES
# ----------------------------
RUN pip install --no-cache-dir -r requirements.txt

# ----------------------------
# COPY PROJECT
# ----------------------------
COPY . .

# ----------------------------
# EXPOSE PORT
# ----------------------------
EXPOSE 5000

# ----------------------------
# RUN APP
# ----------------------------
CMD ["gunicorn", "-w", "2", "-b", "0.0.0.0:5000", "app:app"]